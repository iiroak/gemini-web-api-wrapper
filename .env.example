# Required: API key for authenticating requests to this wrapper
API_KEY=your-secret-api-key-here

# Required: Google cookies for Gemini access
GEMINI_SECURE_1PSID=your-__Secure-1PSID-cookie-value
# Optional: Not all accounts require this
GEMINI_SECURE_1PSIDTS=

# Optional: HTTP/HTTPS proxy
# GEMINI_PROXY=http://proxy:8080

# Optional: Default model (e.g. gemini-3-pro, gemini-3-flash)
GEMINI_MODEL=UNSPECIFIED

# Optional: Timeouts in seconds
GEMINI_TIMEOUT=450
GEMINI_WATCHDOG_TIMEOUT=90
GEMINI_AUTO_REFRESH=true

# Optional: Database path
DATABASE_PATH=data/gemini.db

# Optional: Server bind
HOST=0.0.0.0
PORT=8000
